---
import "../styles/global.css";

import Navbar from "../components/navbar.astro";
import Gallery from "../components/gallery.astro";
import Carousel from "../components/carousel.astro";
import GalleryFilters from "../components/galleryFilters.astro";
import InstagramEmbed from "../components/InstagramEmbed.astro";
import TikTokEmbed from "../components/TikTokEmbed.astro";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/images/logo.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Sumaj Wayras</title>
	</head>
	<body>
		
		<div id="inicio" class="w-full h-full bg-linear-to-r from-gray-950 to-sky-600 bg-fixed">
			<!-- Navbar -->
			<div class="m-8 fixed top-0 left-0 right-0 ">
				<Navbar />
			</div>

			<!-- Main Content -->
			<div class="pt-36 px-8 sm:px-16 md:px-32 lg:px-48">

				<!-- Home -->
				<div class="flex flex-row items-center justify-center bg-white/10 rounded-3xl shadow-lg p-4">
					
					<!-- Text Content Home -->
					<div class="flex flex-col items-center justify-center space-y-8">
						<h1 class="font-bold italic text-cyan-700 text-shadow-lg/100 text-center text-4xl  sm:text-4xl md:text-6xl">Sumaj Wayras</h1>
						<p class="text-cyan-100 text-center max-w-2xl text-shadow-lg/50 text-base sm:text-xl md:text-2xl">
							Bienvenido al Bloque de Tobas - Sumaj Wayras. Rumbo al Corso de Corsos de Cochabamba, <a class="text-cyan-500 text-shadow-lg/100">🎉Carnaval de la Concordia 2026!🎭</a>.
						</p>
						<a href="https://wa.me/59176921712?text=Hola%20Sumaj%20Wayras,%20quiero%20más%20información%20sobre%20el%20bloque." target="_blank" class="text-xs sm:text-base inline-block bg-green-500/75 hover:bg-green-600 text-white font-bold py-2 px-4 rounded-lg shadow-lg text-center">
						Contáctanos en WhatsApp  
						</a>
					</div>
					
					<!-- Image Logo Home -->
					<img src="/images/logo.png" alt="Logo Sumaj Wayras" class="w-1/2 md:w-1/4 drop-shadow-xl/50" />
					
				</div>

				<hr class="text-white m-8">

				<div id="corso" class="bg-white/10 rounded-3xl shadow-lg p-6 md:p-12 my-8 max-w-6xl mx-auto text-white">
					<!-- Título principal -->
					<h2 class="text-2xl md:text-4xl font-bold text-cyan-400 text-center mb-6">
						Sumaj Wayras rumbo al Carnaval de la Concordia 2026! 🎭🪶
					</h2>

					<!-- Texto descriptivo -->
					<p class="text-base md:text-lg text-white/80 mb-6 text-center">
						Bloque Sumaj Wayras 🪶🇧🇴, ingresará con la fraternidad Tobas San Simón ❤️💙 en el Corso de la Concordia 2026. 
						<a class="text-cyan-300 hover:text-cyan-200 font-bold">¡Inscripciones abiertas hasta el 30 de enero o hasta llenar los cupos!</a>
					</p>

					<!-- Info en tarjetas -->
					<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 mb-6 text-white">
						<!-- Ensayos -->
						<div class="bg-white/5 rounded-xl p-4 shadow-inner">
						<h3 class="font-semibold text-cyan-300 mb-2">Ensayos</h3>
						<p>Lunes, Martes y Miércoles</p>
						<p>7:00pm - 8:30pm</p>
						<p>Ubicación: UMSS Paseo Autonómico, frente a la cancha de Economía</p>
						</div>

						<!-- Costos -->
						<div class="bg-white/5 rounded-xl p-4 shadow-inner">
						<h3 class="font-semibold text-cyan-300 mb-2">Costos</h3>
						<ul class="list-disc list-inside">
							<li class="font-bold">370 Bs total (incluye precarnavalera)</li>
							<li>40 Bs inscripción a la fraternidad TSS</li>
							<li>180 Bs Banda (Precarnavalera y Corso)</li>
							<li>100 Bs Alquiler trajes</li>
							<li>Extra 50 Bs letrero distintivo del bloque</li>
						</ul>
						</div>

						<!-- Fechas -->
						<div class="bg-white/5 rounded-xl p-4 shadow-inner">
						<h3 class="font-semibold text-cyan-300 mb-2">Fechas importantes</h3>
						<p>Precarnavalera: 31 de enero ❤️💙</p>
						<p>Corso: 21 de febrero 💙❤️</p>
						</div>
					</div>

					<!-- WhatsApp / contacto -->
					<div class="text-center">
						<p class="mb-4 text-white/80">Si ya estás decidido a ingresar al bloque, únete al grupo de WhatsApp o solicita el enlace al 76921712:</p>
						<a href="https://chat.whatsapp.com/KkJ00gZwxvf7yEMLxPmFQW" target="_blank" class="inline-block bg-green-500 hover:bg-green-600 text-white font-bold py-3 px-6 rounded-lg shadow-lg transition-all">
						Unirme al grupo de WhatsApp
						</a>
					</div>
				</div>

				<hr class="text-white m-8">

				<!-- Tik Tok Embed -->
				<div class="flex flex-col gap-4">
					<blockquote class="tiktok-embed" cite="https://www.tiktok.com/@sumaj.wayras" data-unique-id="sumaj.wayras" data-embed-from="embed_page" data-embed-type="creator" style="max-width:780px; min-width:288px;"> <section> <a target="_blank" href="https://www.tiktok.com/@sumaj.wayras?refer=creator_embed">@sumaj.wayras</a> </section> </blockquote> <script async src="https://www.tiktok.com/embed.js"></script>
				</div>

				<hr class="text-white m-8">

				<!-- Gallery Container-->
				<div id="galeria" class="flex flex-col items-center justify-center bg-white/10 rounded-3xl shadow-lg p-4 gap-4">
					<p class=" text-2xl md:text-4xl items-center text-cyan-500 text-shadow-lg/100">Galeria</p>
					<GalleryFilters />
				</div>

			</div>

			<!-- Instagram Embed -->
			<div id="redes" class="p-8 gap-4 flex flex-col md:flex-row">
				<div class="sk-instagram-feed" data-embed-id="25647931"></div><script src="https://widgets.sociablekit.com/instagram-feed/widget.js" defer></script>
				<div class="sk-instagram-feed" data-embed-id="25647930"></div><script src="https://widgets.sociablekit.com/instagram-feed/widget.js" defer></script>
			</div>
			<!-- Instagram Embed 
			<div>
				<InstagramEmbed url="https://www.instagram.com/dannx_rc/" />
			</div> 
			-->
		</div>
		
		<script async src="https://www.instagram.com/embed.js"></script>
		<script async src="https://www.tiktok.com/embed.js"></script>
		<script is:inline src="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.js"></script>
	</body>
</html>